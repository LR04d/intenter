<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Intenter" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/app_primary</item>
        <item name="colorPrimaryVariant">@color/app_primary_dark</item>
        <item name="colorOnPrimary">@color/app_on_primary</item>
        <item name="colorSecondary">@color/app_secondary</item>
        <item name="colorTertiary">@color/app_tertiary</item>
        <item name="colorSurface">@color/app_surface</item>
        <item name="colorSurfaceVariant">@color/app_surface_alt</item>
        <item name="colorOnSurface">@color/app_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/app_on_surface_variant</item>
        <item name="colorOutline">@color/app_outline</item>
        <item name="colorOutlineVariant">@color/app_outline_variant</item>
        <item name="colorError">@color/app_error</item>
        <item name="colorControlNormal">@color/app_on_surface_variant</item>
        <item name="android:colorBackground">@color/app_page_bg</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:navigationBarColor">@color/app_surface</item>
        <item name="android:statusBarColor">@color/app_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.Intenter" parent="Base.Theme.Intenter" />

    <style name="AppTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeWidth">1.2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <style name="AppEditText" parent="">
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textAppearance">?attr/textAppearanceBodyLarge</item>
    </style>

    <style name="AppTextInputLayoutDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeWidth">1.2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <style name="SectionCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/app_outline_variant</item>
        <item name="cardBackgroundColor">@color/app_surface</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>
</resources>
